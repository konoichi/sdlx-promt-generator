# SDXL Prompt Generator — Konfiguration
# Kopieren als .env und Werte eintragen

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Ollama lokal (provider: ollama_local)
OLLAMA_LOCAL_HOST=http://localhost:11434
OLLAMA_LOCAL_MODEL=llama3.1
OLLAMA_LOCAL_API_KEY=
OLLAMA_LOCAL_TIMEOUT=300

# Ollama Cloud / remote (provider: ollama_cloud)
OLLAMA_CLOUD_HOST=http://srv01:11434
OLLAMA_CLOUD_MODEL=kimi-k2.6:cloud
OLLAMA_CLOUD_API_KEY=
OLLAMA_CLOUD_TIMEOUT=120

# Image Backends
AUTOMATIC1111_HOST=http://localhost:7860
COMFYUI_HOST=http://localhost:8188
IMAGE_BACKEND_TIMEOUT=5

# App
DEFAULT_PROVIDER=anthropic
DATA_DIR=data
HOST=127.0.0.1
PORT=5000
DEBUG=false
